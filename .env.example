# Use apenas a Project URL (Settings → API), SEM /rest/v1 no final
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# URL do backend de scan (OpenAI Vision fica no servidor, não no app)
# Simulador iOS: http://localhost:8000
# Emulador Android: http://10.0.2.2:8000
# Dispositivo físico: http://SEU_IP_LOCAL:8000
EXPO_PUBLIC_SCAN_API_URL=http://localhost:8000
